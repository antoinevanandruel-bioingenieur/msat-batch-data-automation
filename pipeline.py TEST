def clean_msat_data(input_file, output_file):
    """Fonction MSAT pour nettoyer les données et générer un log d'audit trail (QA)."""

    # 1. Chargement des données
    df = pd.read_csv(input_file)
    initial_rows = len(df)

    # 2. Audit pré-nettoyage : Comptage des anomalies de contenu
    # Compte les cases vides pour 'Batch_ID'
    empty_batch_before = df["Batch_ID"].isna().sum()
    # Compte les cases vides pour 'DO_Percent'
    empty_do_before = df["DO_Percent"].isna().sum()

    # 3. Nettoyage des anomalies (Règles métiers MSAT)
  
    # Règle A : On remplit le Batch_ID manquant avec la valeur du dessus. Un lot (run) dure plusieurs jours. 
    # Les lignes vides consécutives appartiennent obligatoirement au même lot. Cela me permet de garatir la traçabilité des mesures.
    # Avec cela, je peux retrouver toutes les lignes où le Batch_ID est encodé quand je fais un filtre plus tard sur le lot. 
    df["Batch_ID"] = df["Batch_ID"].ffill()

    # Règle B : Je supprime la valeur aberrante de 999.0 M/mL (densité impossible) (j'ai inventé ici une limite de 100 M/ml!)
    df = df[df["Viable_Cell_Density_M_mL"] < 100]
    # J'utilise un test logique pour éliminer les valeurs incohérentes. df[...] cache les lignes qui ont répondu FALSE. 
    # Il ne me reste plus qu'à réécrire df= pour remplacer l'ancien tableau par ce nouveau tableau propre. 

    # Règle C : Je remplis le DO_Percent manquant par la moyenne de la colonne. C'est une approximation sans doute pas incroyable.
    # Commentaire: revoir la règle C en utilisant une approximation linéaire plutôt ou autre?

    mean_do = df["DO_Percent"].mean()
    df["DO_Percent"] = df["DO_Percent"].fillna(mean_do)
   # J'utilise .fillna() pour remplirles cases vides avec la moyenne, ce qui permet de maintenir la taille de mon échantillon pour des analyses statistiques futures. 
  
    # 3. Création du Log de Traçabilité (Data Integrity / ALCOA+)
    # Calcul des lignes supprimées
    rows_removed = initial_rows - len(df)
   # Horodatage (le QA pourra vérifier l'heure de l'utilisation de mon code ...
    current_time = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

   # 4. Affichage du GxP Log ultra-complet
    print("\n=============================================")
    print(f"🔬 GxP ADVANCED AUDIT TRAIL LOG [{current_time}]")
    print("=============================================")
    print(f"• Fichier source analysé : {input_file}")
    print(f"• Structure globale     : {rows_removed} ligne(s) détruite(s) (Données aberrantes)")
    print("---------------------------------------------")
    print("• Modifications de contenu (Cases réparées) :")
    print(f"  - [{empty_batch_before}] case(s) vide(s) corrigée(s) pour 'Batch_ID'")
    print(f"  - [{empty_do_before}] case(s) vide(s) imputée(s) par la moyenne ({mean_do:.2f}%) pour 'DO_Percent'")
    print("=============================================\n")

    # Indiquer clairement le nombre de lignes enlevées pour les données incohérentes ET les cases vides corrigées et imputées.
  
    # 5. Exportation
    df.to_csv(output_file, index=False)
    print(f"✅ Étape 3 : Fichier propre '{output_file}' généré.")
    return df


